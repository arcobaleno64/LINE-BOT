{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Line": {
    "ChannelSecret": "<YOUR_CHANNEL_SECRET>",
    "ChannelAccessToken": "<YOUR_CHANNEL_ACCESS_TOKEN>"
  },

  "App": {
    "TimeZoneId": "Asia/Taipei",
    "UserThrottleSecondsText": 3,
    "UserThrottleSecondsImage": 8,
    "UserThrottleSecondsFile": 8,
    "Ai429CooldownSeconds": 12,
    "AiQuotaCooldownSeconds": 300,
    "AiResponseCacheSeconds": 180,
    "AiMergeWindowSeconds": 60
  },

  "WebSearch": {
    "Enabled": true,
    "TavilyApiKey": "<YOUR_TAVILY_API_KEY>",
    "Endpoint": "https://api.tavily.com/search",
    "MaxResults": 4
  },

  "Ai": {
    "Provider": "Gemini",
    "FallbackProvider": "OpenAI",
    "MaxOutputTokens": 4096,
    "OpenAI": {
      "ApiKey": "<YOUR_OPENAI_API_KEY>",
      "Model": "gpt-4o",
      "Endpoint": "https://api.openai.com/v1/chat/completions"
    },
    "Gemini": {
      "ApiKey": "<YOUR_GEMINI_API_KEY>",
      "SecondaryApiKey": "<YOUR_SECONDARY_GEMINI_API_KEY>",
      "Model": "gemini-2.5-flash",
      "FallbackModel": "gemini-2.0-flash-lite",
      "Endpoint": "https://generativelanguage.googleapis.com/v1beta/models"
    },
    "Claude": {
      "ApiKey": "<YOUR_CLAUDE_API_KEY>",
      "Model": "claude-sonnet-4-20250514",
      "Endpoint": "https://api.anthropic.com/v1/messages"
    }
  }
}
